{
  "ConnectionStrings": {
    "meetupDb": "Host=localhost:5435;Database=meetupDb;Username=postgres;Password=postgres;Include Error Detail=true",
    "Redis": "localhost"
  },
  "Authentication": {
    "Audience": "account",
    "TokenValidationParameters": {
      "ValidIssuers": [ "http://emeetup.identity:6001/realms/emeetup", "http://localhost:6001/realms/emeetup" ]
    },
    "MetadataAddress": "http://localhost:6001/realms/emeetup/.well-known/openid-configuration",
    "RequireHttpsMetadata": false
  },
  "KeyCloak": {
    "HealthUrl": "http://localhost:6001/health/"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "Evently.Modules.Attendance.Infrastructure.Outbox": "Warning",
        "Evently.Modules.Attendance.Infrastructure.Inbox": "Warning",
        "Evently.Modules.Events.Infrastructure.Outbox": "Warning",
        "Evently.Modules.Events.Infrastructure.Inbox": "Warning",
        "Evently.Modules.Ticketing.Infrastructure.Outbox": "Warning",
        "Evently.Modules.Ticketing.Infrastructure.Inbox": "Warning",
        "Evently.Modules.Users.Infrastructure.Outbox": "Warning",
        "Evently.Modules.Users.Infrastructure.Inbox": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "eMeetup.Api"
    }
  },
  "Aspire": {
    "Seq": {
      "DisableHealthChecks": true,
      "ServerUrl": "http://localhost:5341"
    }
  }
}